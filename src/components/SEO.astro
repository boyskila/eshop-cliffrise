---
import { DEFAULT_LANG, SUPPORTED_LANGS } from '@constants'
import { getCanonicalSiteUrl, getCanonicalUrl } from '@utils/siteUrls'

export type Image = {
  src: string
  alt: string
}
export type Alternate = {
  lang: string
  href: string | URL
}
export type SEOMetadata = {
  name: string
  title: string
  description: string
  image: Image
  canonicalURL?: URL | string
  locale?: string
  robots?: string
}
export type OpenGraph = Partial<SEOMetadata> & {
  type?: string
}
export type Twitter = Partial<SEOMetadata> & {
  handle?: string
  card?: 'summary' | 'summary_large_image'
}
export type JsonLdItem = Record<string, unknown> & {
  '@context'?: string
  '@type'?: string | string[]
  '@graph'?: Record<string, unknown>[]
}
export type Props = SEOMetadata & {
  alternates?: Alternate[]
  jsonLd?: JsonLdItem | JsonLdItem[]
  og?: OpenGraph
  twitter?: Twitter
}
const {
  name,
  title,
  description,
  image,
  locale: providedLocale,
  robots = 'index,follow',
  alternates = [],
  jsonLd,
  canonicalURL = getCanonicalUrl(Astro.url.pathname),
  og: _og = {},
  twitter: _twitter = {},
} = Astro.props

const baseUrl = getCanonicalSiteUrl()
const openGraphLocales = {
  en: 'en_US',
  bg: 'bg_BG',
} as const

const toAbsoluteUrl = (url: string | URL) => new URL(url.toString(), baseUrl)
const getLocaleFromPathname = () => {
  const firstSegment = Astro.url.pathname.split('/').filter(Boolean)[0]

  return SUPPORTED_LANGS.includes(
    firstSegment as (typeof SUPPORTED_LANGS)[number],
  )
    ? firstSegment
    : DEFAULT_LANG
}
const toOpenGraphLocale = (locale: string) =>
  openGraphLocales[locale as keyof typeof openGraphLocales] ?? locale

const locale = providedLocale ?? getLocaleFromPathname()
const currentOpenGraphLocale = toOpenGraphLocale(locale)
const alternateOpenGraphLocales = Object.values(openGraphLocales).filter(
  (openGraphLocale) => openGraphLocale !== currentOpenGraphLocale,
)

const og: OpenGraph = {
  name,
  title,
  description,
  canonicalURL,
  image,
  locale: currentOpenGraphLocale,
  type: 'website',
  ..._og,
}
const twitter: Twitter = {
  name,
  title,
  description,
  canonicalURL,
  image,
  locale,
  card: 'summary_large_image',
  ..._twitter,
}
const absoluteOgImage = og.image && {
  ...og.image,
  src: toAbsoluteUrl(og.image.src).href,
}
const absoluteTwitterImage = twitter.image && {
  ...twitter.image,
  src: toAbsoluteUrl(twitter.image.src).href,
}

const canonicalHref = getCanonicalUrl(canonicalURL).href
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []
---

<!-- Page Metadata -->
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalHref} />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<meta name="theme-color" content="#000000" />

{
  alternates.map((alternate) => (
    <link
      rel="alternate"
      hreflang={alternate.lang}
      href={getCanonicalUrl(alternate.href).href}
    />
  ))
}

<!-- OpenGraph Tags -->
<meta property="og:title" content={og.title} />
<meta property="og:type" content={og.type} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:locale" content={og.locale} />
{
  alternateOpenGraphLocales.map((locale) => (
    <meta property="og:locale:alternate" content={locale} />
  ))
}
<meta property="og:description" content={og.description} />
<meta property="og:site_name" content={og.name} />
{
  absoluteOgImage && (
    <>
      <meta property="og:image" content={absoluteOgImage.src} />
      <meta property="og:image:alt" content={absoluteOgImage.alt} />
    </>
  )
}

<!-- Twitter Tags -->
{twitter.card && <meta name="twitter:card" content={twitter.card} />}
{twitter.handle && <meta name="twitter:site" content={twitter.handle} />}
<meta name="twitter:title" content={twitter.title} />
<meta name="twitter:description" content={twitter.description} />
{
  absoluteTwitterImage && (
    <>
      <meta name="twitter:image" content={absoluteTwitterImage.src} />
      <meta name="twitter:image:alt" content={absoluteTwitterImage.alt} />
    </>
  )
}

{
  jsonLdItems.map((item) => (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(item)}
      is:inline
    />
  ))
}
