---
import { getLang, getTranslations } from '@utils/i18'
import { Image } from 'astro:assets'
import CityOfTetevenImg from '@assets/city-of-teteven.jpg'

const lang = getLang(Astro.params)
const { causeP1, causeP2 } = getTranslations(Astro.params)
---

<section class="px-10 md:px-25 xl:px-60">
  <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-start">
    <Image
      class="w-full lg:w-3/6 h-auto order-1 lg:order-2"
      src={CityOfTetevenImg}
      alt="Climbing scene"
      widths={[200, 400, 600, 900]}
      sizes="(max-width: 767px) calc(100vw - 80px), (max-width: 1023px) calc(100vw - 200px), (max-width: 1279px) calc(50vw - 124px), calc(50vw - 264px)"
      quality={70}
      fetchpriority="high"
    />
    <div class="order-2 lg:order-1 space-y-6" id="our-cause">
      <img
        class="w-40 sm:w-50 h-auto"
        src={`/titles/${lang}/cause-title.svg`}
        alt="Cause Title"
        loading="eager"
      />
      <article
        class="font-normal text-black text-sm sm:text-base leading-6 pl-6 md:pl-10"
      >
        <p>
          {causeP1}
        </p>
        <p>
          {causeP2}
        </p>
      </article>
    </div>
  </div>
</section>
