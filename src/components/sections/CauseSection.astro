---
import { getTranslations } from '@utils/i18'
import { Image } from 'astro:assets'
import mission from '@assets/images/our_mission.webp'

const { causeP1, causeP2, ourMission } = getTranslations(Astro.params)
---

<section class="px-5 md:px-15 xl:px-55 mb-10 lg:mb-20">
  <div class="flex flex-col lg:flex-row gap-8 lg:gap-15 xl:gap-30 items-start">
    <Image
      src={mission}
      alt="Cliffrise Team"
      class="w-full md:w-[90vw] lg:w-[45vw] xl:w-[35vw] h-auto order-1 lg:order-2 self-end"
      widths={[400, 800, 1200]}
      sizes="(max-width: 767px) calc(100vw - 80px), (max-width: 1023px) calc(100vw - 200px), (min-width: 1024px) 43vw"
      quality={80}
      loading="lazy"
      decoding="async"
    />
    <div class="order-2 lg:order-1 space-y-2" id="our-cause">
      <h1 class="nafta-brush text-[45px] md:text-[55px] lg:text-[80px] mb-4">
        {ourMission}
      </h1>
      <article class="font-normal text-black text-lg leading-6 px-6 md:pl-10">
        <p class="mb-5">
          {causeP1}
        </p>
        <p>
          {causeP2}
        </p>
      </article>
    </div>
  </div>
</section>
