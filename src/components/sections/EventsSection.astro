---
import { getLang, getTranslations } from '@utils/i18'
import GalleryCarousel from '../ui/carousel/GalleryCarousel'
import YearToggle from './YearToggle.astro'
import EventLink from './EventLink.astro'
const { eventsSection } = getTranslations(Astro.params)
const { boldedTextOne, boldedTextTwo, normalTextOne, normalTextTwo, seeEvent } =
  eventsSection
---

<section class="bg-gray-100 py-15 xl:py-22 my-15 xl:my-22">
  <div
    class="px-15
    xl:px-0
    mb-5
    xl:mb-10
    xl:max-w-[75%]
    m-auto
    flex flex-col lg:flex-row
    gap-5 lg:gap-8"
  >
    <img
      id="events-section"
      class="w-70 sm:w-100 h-[95%]"
      src={`/titles/${getLang(Astro.params)}/teteven-climb.svg`}
      alt="Teteven Climb Title"
      loading="lazy"
    />
    <p class="text-base w-full font-normal leading-5">
      <span class="font-bold">{boldedTextOne}</span>
      {normalTextOne}
      <span class="font-bold">{boldedTextTwo}</span>
      {normalTextTwo}
    </p>
  </div>

  <div class="relative xl:max-w-[68%] m-auto">
    <YearToggle />
    <div class="overflow-x-hidden flex items-start justify-center">
      <div data-year-panel="2026" class="w-full">
        <div class="relative">
          <img
            src="/assets/ttvn_meetup_2026.png"
            alt="Тетевен Катери Vol. 2 - Катерачен Фестивал 2026"
            class="object-contain
              w-full
              px-3
              md:max-h-[65%]"
          />
          <EventLink text={seeEvent} />
        </div>
      </div>
      <div data-year-panel="2025" class="hidden w-full">
        <GalleryCarousel client:idle />
      </div>
    </div>
  </div>
</section>
