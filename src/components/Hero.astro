---
import { getLang, getTranslations } from '@utils/i18'

const { heroTitle, productsWithMission } = getTranslations(Astro.params)
---

<section
  class="w-full bg-[url(/assets/mobile/hero.svg)]
  sm:bg-[url(/assets/hero.svg)]
  bg-no-repeat bg-cover pt-3 pb-15 sm:pb-25 tablet-landscape:pb-50 tablet-landscape:pb-[130px] mt-[-1px] lg:pb-[200px] lg:pt-15 relative z-10 overflow-visible"
>
  <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col md:flex-row landscape:flex-row
        justify-between items-center md:gap-10 px-6 lg:justify-center lg:gap-25
        md:mt-5 md:pl-20 md:pr-10
        tablet-landscape:mt-10 tablet-landscape:pl-30 tablet-landscape:pr-20"
    >
      <img
        class="hidden md:block md:max-w-[180px] lg:max-w-[315px] h-auto tablet-landscape:max-w-[200px] landscape:max-w-[300px]"
        alt="CliffRise Logo"
        src="/logos/cliffrise.svg"
        loading="eager"
        fetchpriority="high"
      />

      <div
        class="flex flex-col items-center md:items-start landscape:items-start"
      >
        <h1
          class="nafta-brush text-white text-4xl md:text-[55px] lg:text-[80px] mb-3 lg:mb-7 mt-4"
        >
          {productsWithMission}
        </h1>
        <p
          class="text-white text-lg lg:text-2xl leading-[1.3] max-w-xl text-center lg:mx-0 md:text-left landscape:text-left"
        >
          {heroTitle}
        </p>
      </div>
    </div>
  </div>
  <img
    class="lg:block absolute bottom-[-140px] right-10
    h-40
    md:bottom-[-180px] xl:bottom-[-215px] z-[100] md:right-40
    xl:right-70 md:w-40 md:h-80"
    alt="Climber"
    src="/climber.svg"
    loading="eager"
    fetchpriority="high"
  />
</section>

<style>
  .climber-sway {
    transform-origin: top center;
    animation: climber-sway 10s ease-in-out infinite alternate;
  }

  @keyframes climber-sway {
    from {
      transform: rotate(-20deg);
    }

    to {
      transform: rotate(50deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .climber-sway {
      animation: none;
    }
  }
</style>
