---
import { getLang, getTranslations } from '@utils/i18'

const { heroTitle } = getTranslations(Astro.params)
---

<section
  class="w-full bg-[url(/assets/mobile/hero.svg)] sm:bg-[url(/assets/hero.svg)] bg-no-repeat bg-cover pt-5 pb-20 sm:pb-30 landscape:pb-20 landscape:lg:pb-35 mt-[-1px]"
>
  <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col lg:flex-row landscape:flex-row justify-evenly items-center gap-5 mt-10"
    >
      <img
        class="max-w-[120px] lg:max-w-[250px] h-auto"
        alt="CliffRise Logo"
        src="/logos/cliffrise.svg"
        loading="eager"
        fetchpriority="high"
      />

      <div
        class="flex flex-col gap-3 items-center lg:items-start landscape:items-start"
      >
        <img
          class="w-full max-w-[300px] lg:max-w-[500px] lg:w-auto h-auto"
          src={`/titles/${getLang(Astro.params)}/products-title.svg`}
          alt="Products with mission"
          loading="eager"
          fetchpriority="high"
        />
        <p
          class="font-normal text-white lg:text-xl leading-relaxed max-w-xl lg:mx-0 lg:ml-auto text-center landscape:text-left"
        >
          {heroTitle}
        </p>
      </div>
    </div>
  </div>
  <img
    class="hidden lg:block absolute bottom-[-190px] right-12 xl:right-40 max-h-[800px]"
    alt="Climber"
    src="/hanging-climber.svg"
    loading="eager"
    fetchpriority="high"
  />
</section>
