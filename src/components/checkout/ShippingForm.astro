---
import type { ShippingInfo, Translations } from '@types'
import OfficeSearch from './OfficeSearch.astro'
import OfficeMap from './OfficeMap.astro'
import SubmitButton from './SubmitButton.astro'
import SelectedOffice from './SelectedOffice.astro'

type Props = {
  lang: string
  text: Translations['shipping']
  initialShipping?: ShippingInfo
  isFreeShipping: boolean
  totalWeight: number
}

const { lang, text, initialShipping, isFreeShipping, totalWeight } = Astro.props
---

<div class="size-full max-w-4xl mx-auto px-4 py-8 flex flex-col">
  <h1 class="text-2xl md:text-3xl font-bold mb-8">{text.title}</h1>

  <form
    id="shipping-form"
    class="flex flex-col gap-6 flex-1"
    data-redirect={`/${lang}/checkout/`}
    data-lang={lang}
    data-fee-label={text.shippingFeeLabel}
    data-calculating-fee={text.calculatingFee}
    data-free-shipping={isFreeShipping ? 'true' : 'false'}
    data-total-weight={totalWeight}
    data-selected-office-id={initialShipping?.officeId ?? ''}
    data-selected-office-name={initialShipping?.office ?? ''}
  >
    <div class="flex flex-col flex-1">
      <label class="block text-sm font-medium mb-2">{text.searchLabel}</label>

      <div
        id="office-combined"
        class="border border-black"
        data-initial-office-id={initialShipping?.officeId}
      >
        <SelectedOffice
          officeName={initialShipping?.office}
          changeText={text.changeOffice}
        />

        <OfficeSearch
          className={initialShipping?.office ? 'hidden' : ''}
          lang={lang}
          text={{
            searchPlaceholder: text.searchPlaceholder,
            noResults: text.noResults,
            searchLabel: text.searchLabel,
          }}
        />
      </div>

      <p class="text-sm text-gray-500 mt-2 mb-2">{text.orBrowseMap}</p>

      <OfficeMap
        lang={lang}
        initialOfficeId={initialShipping?.officeId}
        text={{
          workingTime: text.workingTime,
          monFri: text.monFri,
          sat: text.sat,
          selectOffice: text.selectOffice,
          loadingMap: text.loadingMap,
          mapUnavailable: text.mapUnavailable,
        }}
      />

      <p id="error-office" class="text-red-600 text-sm mt-1 hidden">
        {text.required}
      </p>
    </div>

    <SubmitButton text={text.continue} />

    <a
      href={`/${lang}/`}
      class="text-center text-sm text-gray-500 hover:text-black"
    >
      {text.backToShop}
    </a>
  </form>
</div>

<script>
  import { actions } from 'astro:actions'
  import { isPresent } from '../../utils/func'

  const form = document.getElementById('shipping-form') as HTMLFormElement
  const { feeLabel, calculatingFee, freeShipping, totalWeight } =
    form.dataset as {
      feeLabel: string
      calculatingFee: string
      freeShipping: string
      totalWeight: string
    }
  const isFreeShipping = freeShipping === 'true'

  const officeNameElement = document.getElementById(
    'speedy-office-name',
  ) as HTMLElement
  const officeFeeElement = document.getElementById('speedy-fee') as HTMLElement
  const combinedContainer = document.getElementById('office-combined')!
  const selectedPanel = document.getElementById('office-selected-state')!
  const searchState = document.querySelector('[data-office-search]')!
  const searchInput = document.getElementById(
    'office-search-input',
  ) as HTMLInputElement
  const changeButton = document.getElementById(
    'speedy-change',
  ) as HTMLButtonElement

  const showSearch = () => {
    selectedPanel.classList.add('hidden')
    searchState.classList.remove('hidden')
    searchInput.value = ''
    searchInput.focus()
  }

  const showSelected = () => {
    searchState.classList.add('hidden')
    selectedPanel.classList.remove('hidden')
  }

  changeButton.addEventListener('click', showSearch)

  const getOfficeName = () => officeNameElement.textContent?.trim() ?? ''

  let selectedOfficeId: number | null =
    Number(combinedContainer.dataset.initialOfficeId) || null

  const calculateFee = async (officeId: number) => {
    if (isFreeShipping) {
      officeFeeElement.textContent = `${feeLabel} €0.00`
      return
    }
    officeFeeElement.textContent = calculatingFee
    try {
      const { data } = await actions.calculateShipping({
        officeId,
        totalWeight: parseFloat(totalWeight),
      })
      const fee = data?.fee
      officeFeeElement.textContent = isPresent(fee)
        ? `${feeLabel} €${fee.toFixed(2)}`
        : ''
    } catch {
      officeFeeElement.textContent = ''
    }
  }

  const selectOffice = (id: number, name: string) => {
    officeNameElement.textContent = name
    selectedOfficeId = id
    form.dataset.selectedOfficeId = String(id)
    form.dataset.selectedOfficeName = name
    showSelected()
    document.getElementById('error-office')!.classList.add('hidden')

    calculateFee(id)
  }

  if (selectedOfficeId !== null) {
    calculateFee(selectedOfficeId)
    searchState.classList.add('hidden')
  }

  // Listen for search autocomplete selection
  document.addEventListener('office-selected', ((event: CustomEvent) => {
    const { id, name } = event.detail
    if (id && name) {
      selectOffice(id, name)
    }
  }) as EventListener)

  searchInput.addEventListener('blur', () => {
    if (selectedOfficeId) {
      showSelected()
    }
  })

  // Validation for submit button
  form.addEventListener('shipping-validate', ((event: CustomEvent) => {
    const officeName = getOfficeName()
    const errorElement = document.getElementById('error-office')!
    errorElement.classList.toggle('hidden', !!officeName)
    if (!officeName || !selectedOfficeId) {
      event.preventDefault()
    }
  }) as EventListener)
</script>
