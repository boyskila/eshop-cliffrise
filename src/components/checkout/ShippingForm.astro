---
import type { ShippingInfo } from '@types'

type Props = {
  lang: string
  text: {
    title: string
    officeLabel: string
    selectedOffice: string
    changeOffice: string
    continue: string
    backToShop: string
    required: string
    shippingFeeLabel: string
    calculatingFee: string
    selectCaption: string
  }
  initialShipping?: ShippingInfo
  isFreeShipping: boolean
  totalWeight: number
}

const { lang, text, initialShipping, isFreeShipping, totalWeight } = Astro.props

const speedySrc = `https://services.speedy.bg/office_locator_widget_v3/office_locator.php?lang=${lang}&showOfficesList=0&officeType=ALL&officesFilterOnTheMap=1&selectOfficeButtonCaption=${encodeURIComponent(text.selectCaption)}`
---

<div class="w-full max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl md:text-3xl font-bold mb-8">{text.title}</h1>

  <form
    id="shipping-form"
    class="flex flex-col gap-6"
    data-redirect={`/${lang}/checkout/`}
    data-lang={lang}
    data-fee-label={text.shippingFeeLabel}
    data-calculating-fee={text.calculatingFee}
    data-free-shipping={isFreeShipping ? 'true' : 'false'}
    data-total-weight={totalWeight}
  >
    <div>
      <label class="block text-sm font-medium mb-2">{text.officeLabel}</label>

      <div
        id="speedy-iframe-container"
        class={`relative w-full h-[420px] md:h-[500px] border border-black${initialShipping?.office ? ' hidden' : ''}`}
      >
        <iframe
          id="frameOfficeLocator"
          name="frameOfficeLocator"
          src={speedySrc}
          class="absolute inset-0 w-full h-full"></iframe>
      </div>

      <div
        id="speedy-selected"
        class={`border border-black px-3 py-2 flex items-center justify-between gap-4${initialShipping?.office ? '' : ' hidden'}`}
        data-initial-office-id={initialShipping?.officeId}
      >
        <div class="flex flex-col gap-0.5">
          <span id="speedy-office-name" class="text-sm"
            >{initialShipping?.office ?? ''}</span
          >
          <span id="speedy-fee" class="text-sm font-medium text-gray-700"
          ></span>
        </div>
        <button
          type="button"
          id="speedy-change"
          class="text-sm underline shrink-0"
        >
          {text.changeOffice}
        </button>
      </div>

      <p id="error-office" class="text-red-600 text-sm mt-1 hidden">
        {text.required}
      </p>
    </div>

    <button
      id="shipping-submit"
      type="submit"
      class="w-full bg-black text-white p-3 text-lg disabled:opacity-50 disabled:cursor-not-allowed"
    >
      {text.continue}
    </button>

    <a
      href={`/${lang}/`}
      class="text-center text-sm text-gray-500 hover:text-black"
    >
      {text.backToShop}
    </a>
  </form>
</div>

<script>
  import { actions } from 'astro:actions'

  const form = document.getElementById('shipping-form') as HTMLFormElement
  const { redirect, lang, feeLabel, calculatingFee, freeShipping, totalWeight } =
    form.dataset as {
      redirect: string
      lang: string
      feeLabel: string
      calculatingFee: string
      freeShipping: string
      totalWeight: string
    }
  const isFreeShipping = freeShipping === 'true'

  const officeNameEl = document.getElementById(
    'speedy-office-name',
  ) as HTMLElement
  const officeFeeEl = document.getElementById('speedy-fee') as HTMLElement
  const iframeContainer = document.getElementById('speedy-iframe-container')!
  const selectedEl = document.getElementById('speedy-selected')!

  const getOfficeName = () => officeNameEl.textContent?.trim() ?? ''

  const officeDisplayName = (office: Record<string, any>): string =>
    (lang === 'en' ? (office.nameEn ?? office.name) : (office.name ?? office.nameEn)) ??
    office.address?.fullAddressString ??
    JSON.stringify(office)

  let selectedOfficeId: number | null =
    Number(selectedEl.dataset.initialOfficeId) || null

  async function calculateFee(officeId: number) {
    if (isFreeShipping) {
      officeFeeEl.textContent = `${feeLabel} €0.00`
      return
    }
    officeFeeEl.textContent = calculatingFee
    try {
      const { data } = await actions.calculateShipping({
        officeId,
        totalWeight: parseFloat(totalWeight),
      })
      const fee = data?.fee ?? null
      console.log({ fee, totalWeight })

      officeFeeEl.textContent =
        fee != null ? `${feeLabel} €${fee.toFixed(2)}` : ''
    } catch {
      officeFeeEl.textContent = ''
    }
  }

  if (selectedOfficeId !== null) {
    calculateFee(selectedOfficeId)
  }

  window.addEventListener('message', async (e: MessageEvent) => {
    if (e.origin !== 'https://services.speedy.bg') return
    if (!e.data || typeof e.data !== 'object' || Array.isArray(e.data)) return

    officeNameEl.textContent = officeDisplayName(e.data)
    selectedOfficeId = e.data.id ?? null
    iframeContainer.classList.add('hidden')
    selectedEl.classList.remove('hidden')
    document.getElementById('error-office')!.classList.add('hidden')

    if (selectedOfficeId !== null) {
      await calculateFee(selectedOfficeId)

      actions.saveShipping({
        office: getOfficeName(),
        officeId: selectedOfficeId,
      })
    }
  })

  document.getElementById('speedy-change')!.addEventListener('click', () => {
    officeNameEl.textContent = ''
    officeFeeEl.textContent = ''
    selectedOfficeId = null
    iframeContainer.classList.remove('hidden')
    selectedEl.classList.add('hidden')
  })

  form.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault()

    const officeVal = getOfficeName()

    document
      .getElementById('error-office')!
      .classList.toggle('hidden', !!officeVal)

    if (!officeVal || !selectedOfficeId) return

    const btn = document.getElementById('shipping-submit') as HTMLButtonElement
    btn.disabled = true

    const { error } = await actions.saveShipping({
      office: officeVal,
      officeId: selectedOfficeId,
    })

    if (error) {
      console.error('saveShipping failed:', error)
      btn.disabled = false
      return
    }

    window.location.href = redirect
  })
</script>
