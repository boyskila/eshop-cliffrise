---
import type { ShippingInfo } from '@types'

type Props = {
  lang: string
  text: {
    title: string
    nameLabel: string
    namePlaceholder: string
    phoneLabel: string
    phonePlaceholder: string
    officeLabel: string
    selectedOffice: string
    changeOffice: string
    continue: string
    backToShop: string
    required: string
  }
  initialShipping?: ShippingInfo
}

const { lang, text, initialShipping } = Astro.props

const selectCaption = lang === 'bg' ? 'Избери офис' : 'Select this office'
const speedySrc = `https://services.speedy.bg/office_locator_widget_v3/office_locator.php?lang=${lang}&showOfficesList=0&officeType=ALL&officesFilterOnTheMap=1&selectOfficeButtonCaption=${encodeURIComponent(selectCaption)}`
---

<div class="w-full max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl md:text-3xl font-bold mb-8">{text.title}</h1>

  <form
    id="shipping-form"
    class="flex flex-col gap-6"
    data-redirect={`/${lang}/checkout/`}
  >
    <div>
      <label for="shipping-name" class="block text-sm font-medium mb-1">
        {text.nameLabel}
      </label>
      <input
        id="shipping-name"
        type="text"
        placeholder={text.namePlaceholder}
        value={initialShipping?.name ?? ''}
        class="w-full border border-black px-3 py-2 text-base outline-none focus:ring-1 focus:ring-black"
      />
      <p id="error-name" class="text-red-600 text-sm mt-1 hidden">
        {text.required}
      </p>
    </div>

    <div>
      <label for="shipping-phone" class="block text-sm font-medium mb-1">
        {text.phoneLabel}
      </label>
      <input
        id="shipping-phone"
        type="tel"
        placeholder={text.phonePlaceholder}
        value={initialShipping?.phone ?? ''}
        class="w-full border border-black px-3 py-2 text-base outline-none focus:ring-1 focus:ring-black"
      />
      <p id="error-phone" class="text-red-600 text-sm mt-1 hidden">
        {text.required}
      </p>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2">{text.officeLabel}</label>

      <div
        id="speedy-iframe-container"
        class={`relative w-full h-[420px] md:h-[500px] border border-black${initialShipping?.office ? ' hidden' : ''}`}
      >
        <iframe
          id="frameOfficeLocator"
          name="frameOfficeLocator"
          src={speedySrc}
          class="absolute inset-0 w-full h-full"></iframe>
      </div>

      <div
        id="speedy-selected"
        class={`border border-black px-3 py-2 flex items-center justify-between gap-4${initialShipping?.office ? '' : ' hidden'}`}
      >
        <span id="speedy-office-name" class="text-sm">{initialShipping?.office ?? ''}</span>
        <button
          type="button"
          id="speedy-change"
          class="text-sm underline shrink-0"
        >
          {text.changeOffice}
        </button>
      </div>

      <p id="error-office" class="text-red-600 text-sm mt-1 hidden">
        {text.required}
      </p>
    </div>

    <button
      id="shipping-submit"
      type="submit"
      class="w-full bg-black text-white p-3 text-lg disabled:opacity-50 disabled:cursor-not-allowed"
    >
      {text.continue}
    </button>

    <a
      href={`/${lang}/`}
      class="text-center text-sm text-gray-500 hover:text-black"
    >
      {text.backToShop}
    </a>
  </form>
</div>

<script>
  import { actions } from 'astro:actions'

  const form = document.getElementById('shipping-form') as HTMLFormElement
  const { redirect } = form.dataset as { redirect: string }

  const officeNameEl = document.getElementById('speedy-office-name') as HTMLElement
  const iframeContainer = document.getElementById('speedy-iframe-container')!
  const selectedEl = document.getElementById('speedy-selected')!

  const getOfficeName = () => officeNameEl.textContent?.trim() ?? ''

  const officeDisplayName = (office: Record<string, any>): string =>
    office.name ??
    office.nameEn ??
    office.address?.fullAddressString ??
    JSON.stringify(office)

  window.addEventListener('message', (e: MessageEvent) => {
    if (e.origin !== 'https://services.speedy.bg') return
    if (!e.data || typeof e.data !== 'object' || Array.isArray(e.data)) return

    officeNameEl.textContent = officeDisplayName(e.data)
    iframeContainer.classList.add('hidden')
    selectedEl.classList.remove('hidden')
    document.getElementById('error-office')!.classList.add('hidden')
  })

  document.getElementById('speedy-change')!.addEventListener('click', () => {
    officeNameEl.textContent = ''
    iframeContainer.classList.remove('hidden')
    selectedEl.classList.add('hidden')
  })

  form.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault()

    const nameVal = (document.getElementById('shipping-name') as HTMLInputElement).value.trim()
    const phoneVal = (document.getElementById('shipping-phone') as HTMLInputElement).value.trim()
    const officeVal = getOfficeName()

    document.getElementById('error-name')!.classList.toggle('hidden', !!nameVal)
    document.getElementById('error-phone')!.classList.toggle('hidden', !!phoneVal)
    document.getElementById('error-office')!.classList.toggle('hidden', !!officeVal)

    if (!nameVal || !phoneVal || !officeVal) return

    const btn = document.getElementById('shipping-submit') as HTMLButtonElement
    btn.disabled = true

    await actions.saveShipping({
      courier: 'speedy',
      name: nameVal,
      phone: phoneVal,
      office: officeVal,
    })

    window.location.href = redirect
  })
</script>
