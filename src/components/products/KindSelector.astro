---
import { getImage } from 'astro:assets'
import type { Product } from '@types'
import { PRODUCT_IMAGE_SIZES } from '@constants'
import { isString } from '@utils/func'

interface Props {
  product: Product
}

const { product } = Astro.props

const processedKinds = await Promise.all(
  product.kind.map(async ({ image, ...rest }) => {
    let imageUrl: string | undefined
    let imageSrcSet: string | undefined
    if (image) {
      if (isString(image)) {
        imageUrl = image
      } else {
        const processed = await getImage({
          src: image,
          widths: [400, 800, 1200],
          sizes: PRODUCT_IMAGE_SIZES,
          format: 'webp',
          quality: 80,
        })
        imageUrl = processed.src
        imageSrcSet = processed.srcSet.attribute
      }
    }
    return { ...rest, imageUrl, imageSrcSet }
  }),
)
---

{
  product.kind.length > 0 && (
    <div class="flex flex-col gap-4 flex-1">
      <h3 class="text-xl underline underline-offset-2">{product.kindTitle}</h3>
      <ul class="flex flex-wrap gap-1 md:gap-2" data-kind-selector>
        {processedKinds.map(({ name, imageUrl, imageSrcSet, inStock }, kindIndex) => (
          <li>
            <button
              disabled={!inStock}
              title={!inStock ? 'Out of stock' : undefined}
              type="button"
              data-kind-option
              data-kind-index={kindIndex}
              data-kind-name={name}
              data-kind-image={imageUrl}
              data-kind-image-srcset={imageSrcSet}
              data-kind-image-sizes={PRODUCT_IMAGE_SIZES}
              class="
                disabled:opacity-50
                py-1 px-4
                text-[15px] lg:text-lg
                border border-[#D9D9D9]
                uppercase"
            >
              {name}
            </button>
          </li>
        ))}
      </ul>
    </div>
  )
}

<script>
  let kindSelectorController: AbortController | null = null

  document.addEventListener('astro:page-load', () => {
    const selectors = document.querySelectorAll<HTMLElement>(
      '[data-kind-selector]',
    )
    if (!selectors.length) return

    kindSelectorController?.abort()
    kindSelectorController = new AbortController()
    const { signal } = kindSelectorController

    selectors.forEach((selector) => {
      const panel = selector.closest<HTMLElement>('[data-product-container]')
      if (!panel) {
        return
      }

      const kindOptions = Array.from(
        selector.querySelectorAll<HTMLButtonElement>('[data-kind-option]'),
      )
      if (!kindOptions.length) {
        return
      }

      const productImage = panel.querySelector<HTMLImageElement>(
        '[data-product-image]',
      )

      const warmCache = (option: HTMLButtonElement) => {
        const src = option.dataset.kindImage
        if (!src) {
          return
        }
        const img = new Image()
        const srcset = option.dataset.kindImageSrcset
        const sizes = option.dataset.kindImageSizes
        if (srcset) {
          img.srcset = srcset
        }
        if (sizes) {
          img.sizes = sizes
        }
        img.src = src
      }

      const clearKindSelection = () => {
        kindOptions.forEach((option) => {
          option.dataset.selected = 'false'
          option.setAttribute('aria-pressed', 'false')
          option.classList.remove('bg-black', 'text-white', 'border-black')
        })

        window.dispatchEvent(
          new CustomEvent('kind-changed', {
            detail: { kind: null },
          }),
        )
      }

      const setKind = async (kindIndex: string) => {
        const selectedOption = kindOptions.find(
          (option) => option.dataset.kindIndex === kindIndex,
        )
        if (!selectedOption) {
          return
        }

        kindOptions.forEach((option) => {
          const isSelected = option.dataset.kindIndex === kindIndex
          option.dataset.selected = isSelected ? 'true' : 'false'
          option.setAttribute('aria-pressed', isSelected ? 'true' : 'false')
          option.classList.toggle('bg-black', isSelected)
          option.classList.toggle('text-white', isSelected)
          option.classList.toggle('border-black', isSelected)
        })

        const selectedKind = selectedOption.dataset.kindName ?? ''
        const selectedKindImage = selectedOption.dataset.kindImage ?? ''
        const selectedKindImageSrcSet =
          selectedOption.dataset.kindImageSrcset ?? ''
        const selectedKindImageSizes = selectedOption.dataset.kindImageSizes ?? ''

        window.dispatchEvent(
          new CustomEvent('kind-changed', {
            detail: { kind: selectedKind },
          }),
        )

        if (productImage && selectedKindImage.trim().length > 0) {
          const preloader = new Image()
          if (selectedKindImageSrcSet.trim().length > 0) {
            preloader.srcset = selectedKindImageSrcSet
          }
          if (selectedKindImageSizes.trim().length > 0) {
            preloader.sizes = selectedKindImageSizes
          }
          preloader.src = selectedKindImage
          await preloader.decode().catch(() => {})

          productImage.src = selectedKindImage
          if (selectedKindImageSrcSet.trim().length > 0) {
            productImage.srcset = selectedKindImageSrcSet
          } else {
            productImage.removeAttribute('srcset')
          }
          if (selectedKindImageSizes.trim().length > 0) {
            productImage.sizes = selectedKindImageSizes
          }
        }
      }

      kindOptions.forEach((option) => {
        const onIntent = () => warmCache(option)
        option.addEventListener('mouseenter', onIntent, { signal, once: true })
        option.addEventListener('focus', onIntent, { signal, once: true })
        option.addEventListener('touchstart', onIntent, {
          signal,
          once: true,
          passive: true,
        })

        option.addEventListener(
          'click',
          () => {
            const kindIndex = option.dataset.kindIndex ?? '0'
            setKind(kindIndex)
          },
          { signal },
        )
      })

      clearKindSelection()
    })
  })
</script>
