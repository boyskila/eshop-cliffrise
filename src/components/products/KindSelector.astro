---
import type { Product, ProductTranslations } from '@types'

interface Props {
  product: Product
}

const { product } = Astro.props
---

{
  product.kind.length > 0 && (
    <div class="flex flex-col gap-4 flex-1">
      <h3 class="text-xl underline underline-offset-2">{product.kindTitle}</h3>
      <ul class="flex flex-wrap gap-1 md:gap-2" data-kind-selector>
        {product.kind.map(({ name, image, inStock }, kindIndex) => (
          <li>
            <button
              disabled={!inStock}
              title={!inStock ? 'Out of stock' : undefined}
              type="button"
              data-kind-option
              data-kind-index={kindIndex}
              data-kind-name={name}
              data-kind-image={image}
              class="
                disabled:opacity-50
                py-1 px-4
                text-[15px] lg:text-lg
                border border-[#D9D9D9]
                uppercase"
            >
              {name}
            </button>
          </li>
        ))}
      </ul>
    </div>
  )
}

<script>
  let kindSelectorController: AbortController | null = null

  document.addEventListener('astro:page-load', () => {
    const selectors = document.querySelectorAll<HTMLElement>(
      '[data-kind-selector]',
    )
    if (!selectors.length) return

    kindSelectorController?.abort()
    kindSelectorController = new AbortController()
    const { signal } = kindSelectorController

    selectors.forEach((selector) => {
      const panel = selector.closest<HTMLElement>('[data-product-container]')
      if (!panel) {
        return
      }

      const kindOptions = Array.from(
        selector.querySelectorAll<HTMLButtonElement>('[data-kind-option]'),
      )
      if (!kindOptions.length) {
        return
      }

      const productImage = panel.querySelector<HTMLImageElement>(
        '[data-product-image]',
      )

      const clearKindSelection = () => {
        kindOptions.forEach((option) => {
          option.dataset.selected = 'false'
          option.setAttribute('aria-pressed', 'false')
          option.classList.remove('bg-black', 'text-white', 'border-black')
        })

        window.dispatchEvent(
          new CustomEvent('kind-changed', {
            detail: { kind: null },
          }),
        )
      }

      const setKind = (kindIndex: string) => {
        const selectedOption = kindOptions.find(
          (option) => option.dataset.kindIndex === kindIndex,
        )
        if (!selectedOption) {
          return
        }

        kindOptions.forEach((option) => {
          const isSelected = option.dataset.kindIndex === kindIndex
          option.dataset.selected = isSelected ? 'true' : 'false'
          option.setAttribute('aria-pressed', isSelected ? 'true' : 'false')
          option.classList.toggle('bg-black', isSelected)
          option.classList.toggle('text-white', isSelected)
          option.classList.toggle('border-black', isSelected)
        })

        const selectedKind = selectedOption.dataset.kindName ?? ''
        const selectedKindImage = selectedOption.dataset.kindImage ?? ''

        window.dispatchEvent(
          new CustomEvent('kind-changed', {
            detail: { kind: selectedKind },
          }),
        )

        if (productImage && selectedKindImage.trim().length > 0) {
          productImage.src = selectedKindImage
        }
      }

      kindOptions.forEach((option) => {
        option.addEventListener(
          'click',
          () => {
            const kindIndex = option.dataset.kindIndex ?? '0'
            setKind(kindIndex)
          },
          { signal },
        )
      })

      clearKindSelection()
    })
  })
</script>
