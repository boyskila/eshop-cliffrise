---
import type { ProductGalleryImage } from '@types'

type Props = {
  productName: string
  productImages: ProductGalleryImage[]
}

const { productName, productImages } = Astro.props
---

{
  productImages.length > 1 && (
    <ul class="flex gap-2 flex-wrap">
      {productImages.map(({ thumbnail, full }) => (
        <li>
          <button
            data-product-thumbnail
            data-image-src={full.src}
            data-image-srcset={full.srcSet}
            data-image-sizes={full.sizes}
            class="
              size-14
              cursor-pointer
              hover:border
              hover:border-black"
          >
            <img
              src={thumbnail.src}
              alt={productName}
              class="bg-shimmer size-full object-cover"
              width="56"
              height="56"
              loading="lazy"
            />
          </button>
        </li>
      ))}
    </ul>
  )
}

<script>
  const mainImage = document.getElementById(
    'product-main-image',
  ) as HTMLImageElement | null
  const imageOverlay = document.querySelector<HTMLImageElement>(
    '[data-product-image-overlay]',
  )
  const thumbnails = document.querySelectorAll<HTMLButtonElement>(
    '[data-product-thumbnail]',
  )
  let latestSwap = 0

  const setImageSource = (
    image: HTMLImageElement,
    src: string,
    srcset: string,
    sizes: string,
  ) => {
    if (sizes) {
      image.sizes = sizes
    } else {
      image.removeAttribute('sizes')
    }

    if (srcset) {
      image.srcset = srcset
    } else {
      image.removeAttribute('srcset')
    }

    image.src = src
  }

  const decodeImage = async (image: HTMLImageElement) => {
    try {
      await image.decode()
      return image.naturalWidth > 0
    } catch {
      return false
    }
  }

  const warmCache = (thumb: HTMLButtonElement) => {
    const src = thumb.dataset.imageSrc
    if (!src) {
      return
    }
    const img = new Image()
    setImageSource(
      img,
      src,
      thumb.dataset.imageSrcset ?? '',
      thumb.dataset.imageSizes ?? '',
    )
    void decodeImage(img)
  }

  thumbnails.forEach((thumb) => {
    const onIntent = () => warmCache(thumb)
    thumb.addEventListener('mouseenter', onIntent, { once: true })
    thumb.addEventListener('focus', onIntent, { once: true })
    thumb.addEventListener('touchstart', onIntent, {
      once: true,
      passive: true,
    })

    thumb.addEventListener('click', async () => {
      const src = thumb.dataset.imageSrc
      const srcset = thumb.dataset.imageSrcset ?? ''
      const sizes = thumb.dataset.imageSizes ?? ''
      if (!mainImage || !src) {
        return
      }

      const swap = ++latestSwap
      const preloader = new Image()
      setImageSource(preloader, src, srcset, sizes)

      if (!(await decodeImage(preloader)) || swap !== latestSwap) {
        return
      }

      if (!imageOverlay) {
        setImageSource(mainImage, src, srcset, sizes)
        return
      }

      imageOverlay.style.opacity = '0'
      setImageSource(imageOverlay, src, srcset, sizes)

      if (!(await decodeImage(imageOverlay)) || swap !== latestSwap) {
        return
      }

      imageOverlay.style.opacity = '1'
      setImageSource(mainImage, src, srcset, sizes)

      if ((await decodeImage(mainImage)) && swap === latestSwap) {
        imageOverlay.style.opacity = '0'
      }
    })
  })
</script>
