---
import CookieBanner from '@components/CookieBanner.astro'
import GoogleAnalytics from '@components/GoogleAnalytics.astro'
import SEO from '@components/SEO.astro'
import { getLang, getTranslations } from '@utils/i18'
import { getCanonicalSiteUrl } from '@utils/siteUrls'
import '../styles/global.css'

const lang = getLang(Astro.params)
const { cookieBanner } = getTranslations(Astro.params)
const baseUrl = getCanonicalSiteUrl()
const title = 'Checkout | CliffRise Shop'
const description =
  'Secure checkout for CliffRise climbing products and route-funding purchases.'

Astro.response.headers.set('Cache-Control', 'no-store')
---

<!doctype html>
<html lang={Astro.params.lang} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <SEO
      name="CliffRise Shop"
      {title}
      {description}
      image={{
        src: new URL('/CR_Featured_Image.webp', baseUrl).href,
        alt: 'CliffRise Shop',
      }}
      locale={lang}
      robots="noindex,nofollow"
    />
    <GoogleAnalytics />
  </head>
  <body class="h-full">
    <slot />
    <CookieBanner lang={lang} text={cookieBanner} />
  </body>
</html>
