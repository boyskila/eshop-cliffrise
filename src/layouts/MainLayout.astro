---
import SEO from '@components/SEO.astro'
import { getLang, getTranslations } from '@utils/i18'
import Header from '@components/header/Header.astro'
import Hero from '@components/Hero.astro'
import Footer from '@components/Footer.astro'
import { CartNotifications } from '@components/CartNotifications'
import { Cart } from '@components/cart/Cart'
import Divider from '@components/ui/Divider.astro'
import ContactUsModal from '@components/contactForm/ContactUsModal.astro'
import CookieBanner from '@components/CookieBanner.astro'
import GoogleAnalytics from '@components/GoogleAnalytics.astro'
import { DEFAULT_LANG, SUPPORTED_LANGS } from '@constants'
import {
  buildBaseSchemaGraph,
  buildSchemaDocument,
  normalizeSchemaNodes,
} from '@utils/schema'
import '../styles/global.css'

type SEOImage = {
  src: string
  alt: string
}

interface Props {
  title: string
  seoTitle?: string
  showHero?: boolean
  description?: string
  image?: SEOImage
  robots?: string
  canonicalURL?: URL | string
  jsonLd?: unknown | unknown[]
  og?: {
    type?: string
  }
}

const baseUrl = Astro.site ?? Astro.url
const defaults = {
  name: 'CliffRise Shop',
  description:
    'CliffRise is a climbing brand supporting real work on the rock in Bulgaria - helping create new routes and maintain climbing areas for the community.',
  image: {
    src: new URL('/CR_Featured_Image.webp', baseUrl).href,
    alt: 'CliffRise Shop',
  },
} as const

const {
  showHero = true,
  title,
  seoTitle,
  description = defaults.description,
  image = defaults.image,
  robots = 'index,follow',
  canonicalURL = new URL(Astro.url.pathname, baseUrl),
  jsonLd,
  og,
} = Astro.props
const { notification, cart, cookieBanner, seo } = getTranslations(Astro.params)
const lang = getLang(Astro.params)

const formatTitle = (pageTitle: string) =>
  pageTitle.includes('CliffRise') ? pageTitle : `${pageTitle} | CliffRise Shop`
const formattedTitle = formatTitle(seoTitle ?? title)

const getLocalizedPathname = (locale: string) => {
  const segments = Astro.url.pathname.split('/').filter(Boolean)

  if (
    SUPPORTED_LANGS.includes(segments[0] as (typeof SUPPORTED_LANGS)[number])
  ) {
    segments[0] = locale
  } else {
    segments.unshift(locale)
  }

  return `/${segments.join('/')}/`
}

const alternates = [
  ...SUPPORTED_LANGS.map((locale) => ({
    lang: locale,
    href: new URL(getLocalizedPathname(locale), baseUrl),
  })),
  {
    lang: 'x-default',
    href: new URL(getLocalizedPathname(DEFAULT_LANG), baseUrl),
  },
]

const schema = buildSchemaDocument([
  ...buildBaseSchemaGraph({
    baseUrl,
    lang,
    websiteDescription: seo.home.description,
    pageTitle: formattedTitle,
    pageDescription: description,
    canonicalURL,
    image,
  }),
  ...normalizeSchemaNodes(jsonLd),
])
---

<!doctype html>
<html lang={Astro.params.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <SEO
      name={defaults.name}
      title={formattedTitle}
      {description}
      {image}
      locale={lang}
      {robots}
      {canonicalURL}
      {alternates}
      jsonLd={schema}
      og={{ type: 'website', ...og }}
    />
    <GoogleAnalytics />
  </head>
  <body class="[&:has([data-cart-dialog])]:overflow-hidden">
    <Header />
    <Cart
      lang={lang}
      text={{
        title: cart.title,
        empty: cart.empty,
        emptyDescBeforeProducts: cart.emptyDescBeforeProducts,
        emptyDescProductsLink: cart.emptyDescProductsLink,
        emptyDescAfterProducts: cart.emptyDescAfterProducts,
        total: cart.total,
        checkout: cart.checkout,
        routeFunding: cart.routeFunding,
      }}
      client:load
    />
    <CartNotifications
      client:visible
      text={{
        addedToCart: notification.addedToCart,
        routeFunding: notification.routeFunding,
      }}
      lang={lang}
    />
    {showHero && <Hero />}
    <main>
      <slot />
    </main>
    <Divider />
    <Footer />
    <ContactUsModal />
    <CookieBanner lang={lang} text={cookieBanner} />
  </body>
</html>
