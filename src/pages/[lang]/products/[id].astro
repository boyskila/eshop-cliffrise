---
import MainLayout from '@layouts/MainLayout.astro'
import { getTranslations, getLang } from '@utils/i18'
import { getProducts } from '@data/products'
import { AddToCartButton } from '@components/products/AddToCartButton'
import ProductsCarousel from '@components/ui/carousel/ProductsCarousel'
import KindSelector from '@components/products/KindSelector.astro'
import { QuantityControls } from '@components/products/QuantityControls'
import ImageThumbnails from '@components/products/ImageThumbnails.astro'
import { Price } from '@components/ui/Price'
import {
  prepareProductCards,
  prepareProductGalleryImages,
  prepareProductKinds,
  prepareProductMainImage,
} from '@utils/image'
import { getFreeShippingThreshold } from '@utils/shipping'
import {
  getOrganizationId,
  getProductId,
  getSchemaLanguage,
  getWebPageId,
} from '@utils/schema'

const translations = getTranslations(Astro.params)
const lang = getLang(Astro.params)
const products = await getProducts(lang)
const { id } = Astro.params

const product = products.find((p) => p.slug === id)

if (!product) {
  return Astro.redirect(`/${lang}/products/`)
}

const productGalleryImages = await prepareProductGalleryImages(product.images)
const mainImage =
  productGalleryImages[0]?.full ??
  (await prepareProductMainImage(product.image))
const renderedProductKinds = await prepareProductKinds(product.kind)
const carouselProducts = await prepareProductCards(products)
const productRequiresKindSelection = product.kind.length > 0
const productOutOfStock = product.outOfStock ?? false
const freeShippingThreshold = await getFreeShippingThreshold()
const baseUrl = Astro.site ?? Astro.url
const canonicalURL = new URL(product.href, baseUrl)
const productImageUrl = new URL(mainImage.src, baseUrl).href
const productImageUrls = productGalleryImages.map(
  ({ full }) => new URL(full.src, baseUrl).href,
)
const productSeo = translations.seo.product
const replaceProductSeoPlaceholders = (value: string) =>
  value.replaceAll('{productName}', product.name)
const productSummary =
  product.description ||
  replaceProductSeoPlaceholders(productSeo.fallbackDescription)
const productDescription = replaceProductSeoPlaceholders(
  productSeo.description,
).replaceAll('{productDescription}', productSummary)
const seoTitle = replaceProductSeoPlaceholders(productSeo.title)
const seoDescription =
  productDescription.length > 155
    ? `${productDescription.slice(0, 152).trim()}...`
    : productDescription
const breadcrumbLabels = {
  en: {
    home: 'Home',
  },
  bg: {
    home: 'Начало',
  },
} as const
const labels = breadcrumbLabels[lang]
const homeLabel = labels.home
const organizationId = getOrganizationId(baseUrl)
const productId = getProductId(canonicalURL)
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': productId,
  name: product.name,
  sku: product.id,
  url: canonicalURL.href,
  description: productDescription,
  image: productImageUrls.length > 0 ? productImageUrls : [productImageUrl],
  category: 'Climbing equipment',
  inLanguage: getSchemaLanguage(lang),
  mainEntityOfPage: {
    '@id': getWebPageId(canonicalURL),
  },
  brand: {
    '@id': organizationId,
  },
  offers: {
    '@type': 'Offer',
    '@id': `${productId}-offer`,
    url: canonicalURL.href,
    priceCurrency: 'EUR',
    price: product.price.toFixed(2),
    availability: productOutOfStock
      ? 'https://schema.org/OutOfStock'
      : 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    seller: {
      '@id': organizationId,
    },
  },
}
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${productId}-breadcrumb`,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: homeLabel,
      item: new URL(`/${lang}/`, baseUrl).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: translations.products,
      item: new URL(`/${lang}/#products`, baseUrl).href,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: product.name,
      item: canonicalURL.href,
    },
  ],
}
---

<MainLayout
  title={product.name}
  {seoTitle}
  description={seoDescription}
  image={{ src: productImageUrl, alt: product.name }}
  {canonicalURL}
  jsonLd={[productJsonLd, breadcrumbJsonLd]}
  og={{ type: 'product' }}
  showHero={false}
>
  <div
    data-product-free-delivery-banner
    class="uppercase text-center bg-gray-100 py-4 text-2xl tracking-widest"
  >
    {translations.freeDelivery}
    <Price amount={freeShippingThreshold} lang={lang} />
  </div>
  <section class="pt-10 px-6 md:px-8 lg:px-12 max-w-7xl mx-auto">
    <div
      data-product-container
      class="flex phone-landscape:flex-row flex-col md:flex-row gap-5 md:gap-12"
    >
      <div class="flex-1 min-w-0">
        <div class="relative aspect-square mb-4">
          <img
            id="product-main-image"
            data-product-image
            src={mainImage.src}
            srcset={mainImage.srcSet}
            sizes={mainImage.sizes}
            alt={product.name}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="bg-shimmer w-full h-full object-cover"
          />
          <img
            data-product-image-overlay
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0"
          />
          {
            productOutOfStock && (
              <div
                data-product-stock-banner
                class="absolute top-5 -left-5 md:-left-16 bg-black
                text-white px-8 md:px-10 py-3 md:py-4 text-lg
                md:text-2xl font-medium uppercase tracking-[2px] z-10"
              >
                {translations.comingSoon}
              </div>
            )
          }
        </div>
        <ImageThumbnails
          productImages={productGalleryImages}
          productName={product.name}
        />
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <h1 class="text-3xl md:text-4xl lg:text-[45px] font-bold xl:mb-3">
          {product.productPageTitle ?? product.name}
        </h1>
        <p
          class="text-gray-600 text-lg/6 xl:text-xl/7 mb-3 md:mb-0"
          class:list={{ 'flex-1': product.kind.length === 0 }}
        >
          {product.description}
        </p>

        {
          renderedProductKinds.length > 0 && (
            <KindSelector
              kindTitle={product.kindTitle}
              productKinds={renderedProductKinds}
              disabled={productOutOfStock}
            />
          )
        }

        <div class="flex justify-between items-center">
          <QuantityControls productName={product.name} client:visible />
          <Price
            amount={product.price}
            amountBgn={product.priceBgn}
            lang={lang}
            bgnClass="md:text-xl"
            class="font-bold text-2xl md:text-3xl"
          />
        </div>
        <div class="flex items-center gap-4 mt-4">
          <AddToCartButton
            productName={product.name}
            productId={product.id}
            lang={lang}
            label={translations.addToCart}
            disabled={productRequiresKindSelection || productOutOfStock}
            client:load
          />
        </div>
      </div>
    </div>
  </section>
  <div class="w-full bg-black h-[1px] my-8 md:my-15 xl:my-20"></div>
  <section id="products" class="flex-col justify-center px-3 md:px-7 lg:px-10">
    <h1
      class="leading-10 md:leading-20 nafta-brush text-[45px] md:text-[55px] lg:text-[80px] mb-7 xl:mb-15 text-center"
    >
      {translations.seeAlso}
    </h1>
    <ProductsCarousel
      products={carouselProducts}
      buttonText={translations.buyNow}
      lang={lang}
      client:visible
    />
  </section>
</MainLayout>
