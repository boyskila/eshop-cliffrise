---
import MainLayout from '@layouts/MainLayout.astro'
import {
  ProductsSection,
  EventsSection,
  AboutSection,
  CauseSection,
  FeedbackSection,
} from '@components/sections'
import Divider from '@components/ui/Divider.astro'
import { getTranslations } from '@utils/i18'

const translations = getTranslations(Astro.params)
const title = translations.seo.home.title
const description = translations.seo.home.description
---

<MainLayout {title} {description}>
  <CauseSection />
  <EventsSection />
  <AboutSection />
  <Divider />
  <ProductsSection />
  <Divider />
  <FeedbackSection />
</MainLayout>
